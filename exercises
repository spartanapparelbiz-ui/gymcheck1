<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
<meta name="theme-color" content="#f3efe6" />
<title>Exercise Library — GYMcheck.</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%230d0d0d'/%3E%3Ctext x='3' y='25' font-family='Impact,Anton,sans-serif' font-size='26' font-weight='900' fill='%23f3efe6'%3EG%3C/text%3E%3Ccircle cx='27' cy='25' r='3.5' fill='%23ff2d00'/%3E%3C/svg%3E" />
<meta name="description" content="The form encyclopedia. 60+ exercises with how-to, common mistakes, and what we check in your form." />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600;700;800&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />

<style>
:root{
  --bg:#f3efe6;
  --paper:#ede8dd;
  --ink:#0d0d0d;
  --ink-soft:#3a3a3a;
  --accent:#ff2d00;
  --acid:#d8ff00;
  --muted:#666;
  --good:#1a8f4a;
  --warn:#ff6f00;
  --bad:#cc1a1a;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--ink);overflow-x:hidden;line-height:1.55}
img{max-width:100%;display:block}
button{font-family:inherit;cursor:pointer}
a{color:inherit;text-decoration:none}

body::before{
  content:"";position:fixed;inset:0;pointer-events:none;z-index:1;opacity:0.08;
  background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='1.4' numOctaves='2'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
  mix-blend-mode:multiply;
}

/* GLOBAL ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
@keyframes spinSlow{from{transform:rotate(0)}to{transform:rotate(360deg)}}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}

/* TYPOGRAPHY — premium */
.gc-logo{
  font-family:'Anton',sans-serif;
  font-size:30px;
  letter-spacing:-0.005em;
  text-transform:uppercase;
  color:var(--ink);
  line-height:0.85;
  display:inline-flex;
  align-items:baseline;
  position:relative;
  transition:opacity .25s ease;
  -webkit-font-smoothing:antialiased;
  text-rendering:geometricPrecision;
  font-feature-settings:'kern' 1, 'liga' 1;
}
.gc-logo:hover{opacity:0.78}
.gc-logo .gc-prefix{display:inline-block;margin-right:0.02em}
.gc-logo .check{font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;text-transform:lowercase;letter-spacing:-0.035em;color:var(--accent);font-size:1.06em;margin-left:-0.04em}
.gc-logo .dot{display:inline-block;width:0.18em;height:0.18em;background:var(--accent);margin-left:0.06em;vertical-align:baseline;position:relative;top:-0.01em;flex-shrink:0;color:transparent;font-size:0}

/* === EXCLUSIVE INDICATOR === */
.exclusive-stripe{position:fixed;top:0;left:0;right:0;height:2px;background:var(--ink);z-index:55}
.exclusive-stripe::after{content:"";position:absolute;top:0;left:0;width:32%;height:100%;background:var(--accent)}

/* NAV */
.nav{position:sticky;top:2px;z-index:50;display:flex;justify-content:space-between;align-items:center;padding:18px 28px;border-bottom:1px solid var(--ink);background:var(--bg);transition:padding .25s ease, box-shadow .25s ease, backdrop-filter .25s ease}
.nav.scrolled{padding:12px 28px;box-shadow:0 2px 0 var(--ink), 0 8px 24px rgba(0,0,0,0.08);background:rgba(243,239,230,0.92);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px)}
.nav .gc-logo{font-size:26px;transition:font-size .25s ease}
.nav.scrolled .gc-logo{font-size:22px}
.nav-right{display:flex;gap:8px;align-items:center}
.nav-right a{padding:9px 16px;font-size:12px;font-weight:600;border:1.5px solid var(--ink);transition:all .2s cubic-bezier(.2,.9,.3,1);letter-spacing:0.02em;position:relative;overflow:hidden}
.nav-right a::before{content:"";position:absolute;inset:0;background:var(--ink);transform:scaleX(0);transform-origin:right;transition:transform .3s cubic-bezier(.2,.9,.3,1);z-index:-1}
.nav-right a:hover{color:var(--bg);border-color:var(--ink)}
.nav-right a:hover::before{transform:scaleX(1);transform-origin:left}
.nav-right a.cta{background:var(--ink);color:var(--bg)}
.nav-right a.cta::before{background:var(--accent)}
.nav-right a.cta:hover{color:var(--ink);border-color:var(--accent)}
.nav-right a.current{background:var(--accent);color:var(--bg);border-color:var(--accent)}

/* PAGE HEADER */
.page-header{padding:80px 28px 48px;border-bottom:1px solid var(--ink);background:var(--bg);position:relative}
.page-header-inner{max-width:1280px;margin:0 auto}
.page-eyebrow{font-size:11px;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:var(--accent);margin-bottom:14px}
.page-title{font-family:'Anton',sans-serif;font-size:clamp(64px,10vw,128px);line-height:0.85;letter-spacing:-0.02em;text-transform:uppercase;margin-bottom:20px}
.page-title .ital{font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;text-transform:none;color:var(--accent)}
.page-lede{font-family:'Instrument Serif',serif;font-style:italic;font-size:22px;color:var(--ink-soft);max-width:680px;line-height:1.4}

/* FILTER BAR — search + category tabs */
.filter-bar{background:var(--ink);color:var(--bg);padding:18px 28px;border-bottom:1px solid var(--ink);position:sticky;top:62px;z-index:40;transition:top .25s ease}
.filter-inner{max-width:1280px;margin:0 auto;display:flex;gap:14px;align-items:center;flex-wrap:wrap}
.filter-search-wrap{position:relative;flex:1;min-width:240px;max-width:400px}
.filter-search{width:100%;padding:11px 36px 11px 36px;border:2px solid #2a2a2a;background:#0d0d0d;color:var(--bg);font-family:'Inter',sans-serif;font-size:14px;font-weight:500;transition:border-color .2s ease}
.filter-search:focus{outline:none;border-color:var(--accent)}
.filter-search::placeholder{color:#666;font-style:italic}
.filter-search-wrap::before{content:"⌕";position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:18px;color:var(--accent);pointer-events:none;font-weight:700}
.filter-cats{display:flex;gap:6px;flex-wrap:wrap}
.filter-cat{padding:8px 12px;border:1.5px solid #2a2a2a;background:#0d0d0d;color:var(--bg);font-family:'Anton',sans-serif;font-size:11px;letter-spacing:0.06em;text-transform:uppercase;cursor:pointer;transition:all .2s cubic-bezier(.2,.9,.3,1);line-height:1}
.filter-cat:hover{background:#1a1a1a;transform:translateY(-1px)}
.filter-cat.active{background:var(--accent);color:var(--bg);border-color:var(--accent);transform:translateY(-1px);box-shadow:0 2px 0 var(--acid)}

/* EXERCISE GRID */
.ex-grid-section{padding:48px 28px 80px;position:relative;z-index:2}
.ex-grid-inner{max-width:1280px;margin:0 auto}
.ex-count{font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:18px}
.ex-count b{color:var(--accent)}
.ex-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px}
.ex-card{background:var(--bg);border:2px solid var(--ink);padding:22px;cursor:pointer;transition:transform .35s cubic-bezier(.2,.9,.3,1), box-shadow .35s cubic-bezier(.2,.9,.3,1), background .25s ease;position:relative;overflow:hidden;will-change:transform}
.ex-card::before{content:"";position:absolute;top:0;left:0;width:100%;height:0;background:linear-gradient(180deg,var(--accent),transparent 60%);transition:height .4s cubic-bezier(.2,.9,.3,1);opacity:0.08;pointer-events:none}
.ex-card:hover{transform:translate(-4px,-4px);box-shadow:8px 8px 0 var(--accent), 0 12px 24px rgba(0,0,0,0.12);z-index:2}
.ex-card:hover::before{height:100%}
.ex-card-tag{display:inline-block;font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:3px 7px;background:var(--ink);color:var(--bg);margin-bottom:10px}
.ex-card-tag.big4{background:var(--accent)}
.ex-card-tag.legs{background:#1a8f4a;color:var(--bg)}
.ex-card-tag.push{background:#ff6f00;color:var(--bg)}
.ex-card-tag.pull{background:#0066cc;color:var(--bg)}
.ex-card-tag.core{background:#9b59b6;color:var(--bg)}
.ex-card-tag.oly{background:var(--acid);color:var(--ink)}
.ex-card-tag.cardio{background:#444;color:var(--bg)}
.ex-card h3{font-family:'Anton',sans-serif;font-size:24px;line-height:0.95;letter-spacing:0.01em;text-transform:uppercase;margin-bottom:6px}
.ex-card .ex-desc{font-size:13px;color:var(--ink-soft);line-height:1.45;margin-bottom:12px}
.ex-card .ex-arrow{display:flex;align-items:center;gap:6px;font-family:'Anton',sans-serif;font-size:12px;color:var(--accent);letter-spacing:0.06em;text-transform:uppercase}
.ex-card .ex-arrow .arrow{font-family:'Instrument Serif',serif;font-style:italic;font-size:16px;transition:transform .25s ease}
.ex-card:hover .ex-arrow .arrow{transform:translateX(6px)}

.ex-empty{padding:60px 20px;text-align:center;color:var(--muted);font-family:'Instrument Serif',serif;font-style:italic;font-size:20px}
.ex-empty a{color:var(--accent);font-weight:700;cursor:pointer;text-decoration:underline;font-family:'Inter',sans-serif;font-style:normal}

/* EXERCISE DETAIL PANEL (slides in) */
.detail-panel{position:fixed;top:0;right:0;bottom:0;width:min(720px,100%);background:var(--bg);z-index:200;transform:translateX(100%);transition:transform .45s cubic-bezier(.2,.9,.3,1);box-shadow:-30px 0 60px rgba(0,0,0,0.3);overflow-y:auto;display:flex;flex-direction:column}
.detail-panel.open{transform:translateX(0)}
.detail-overlay{position:fixed;inset:0;background:rgba(13,13,13,0.6);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);z-index:199;opacity:0;visibility:hidden;transition:opacity .35s ease, visibility .35s ease}
.detail-overlay.open{opacity:1;visibility:visible}
.detail-head{padding:28px 32px;background:var(--ink);color:var(--bg);position:sticky;top:0;z-index:5;border-bottom:1px solid #2a2a2a}
.detail-close{position:absolute;top:18px;right:24px;width:38px;height:38px;display:flex;align-items:center;justify-content:center;background:transparent;border:1.5px solid var(--bg);color:var(--bg);font-size:20px;cursor:pointer;transition:all .25s ease}
.detail-close:hover{background:var(--accent);border-color:var(--accent);transform:rotate(90deg)}
.detail-cat{font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--accent);margin-bottom:8px}
.detail-name{font-family:'Anton',sans-serif;font-size:44px;line-height:0.95;letter-spacing:0.01em;text-transform:uppercase;color:var(--bg)}
.detail-name .ital{font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;text-transform:none;color:var(--accent)}
.detail-body{padding:32px;flex:1}
.detail-section{margin-bottom:36px}
.detail-section h3{font-family:'Anton',sans-serif;font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:var(--accent);margin-bottom:14px;padding-bottom:8px;border-bottom:2px solid var(--ink)}
.detail-section p{font-size:15px;line-height:1.6;color:var(--ink-soft);margin-bottom:10px}
.detail-section p b{color:var(--ink)}
.detail-steps{counter-reset:dst;display:grid;gap:12px}
.detail-step{display:grid;grid-template-columns:48px 1fr;gap:18px;align-items:start}
.detail-step::before{counter-increment:dst;content:counter(dst);font-family:'Anton',sans-serif;font-size:32px;color:var(--accent);line-height:0.9;letter-spacing:-0.02em}
.detail-step .ds-body{font-size:14px;line-height:1.55;color:var(--ink-soft);padding-top:4px}
.detail-step .ds-body b{color:var(--ink);font-weight:700}
.detail-mistakes{display:grid;gap:8px}
.detail-mistake{display:flex;gap:12px;align-items:flex-start;padding:12px 14px;background:var(--paper);border-left:3px solid var(--bad);font-size:14px;line-height:1.5;color:var(--ink-soft);transition:transform .25s cubic-bezier(.2,.9,.3,1)}
.detail-mistake:hover{transform:translateX(4px)}
.detail-mistake .mi-x{color:var(--bad);font-weight:700;flex-shrink:0;font-size:18px;line-height:1}
.detail-mistake b{color:var(--ink)}
.detail-cues{display:grid;gap:8px}
.detail-cue{display:flex;gap:12px;align-items:flex-start;padding:12px 14px;background:var(--paper);border-left:3px solid var(--good);font-size:14px;line-height:1.5;color:var(--ink-soft);transition:transform .25s cubic-bezier(.2,.9,.3,1)}
.detail-cue:hover{transform:translateX(4px)}
.detail-cue .mi-check{color:var(--good);font-weight:700;flex-shrink:0;font-size:18px;line-height:1}
.detail-cue b{color:var(--ink)}
.detail-checked{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.detail-check-chip{padding:10px 14px;background:var(--ink);color:var(--bg);font-family:'Inter',sans-serif;font-size:13px;font-weight:600;border-left:3px solid var(--accent);transition:transform .25s ease}
.detail-check-chip:hover{transform:translateX(4px)}
.detail-cta{padding:24px 32px;border-top:2px solid var(--ink);background:var(--paper);position:sticky;bottom:0}
.detail-cta-btn{width:100%;padding:18px;background:var(--ink);color:var(--bg);font-family:'Anton',sans-serif;font-size:18px;letter-spacing:0.04em;text-transform:uppercase;border:2px solid var(--ink);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;transition:all .25s cubic-bezier(.2,.9,.3,1);position:relative;overflow:hidden}
.detail-cta-btn::before{content:"";position:absolute;inset:0;background:var(--accent);transform:translateX(-101%);transition:transform .35s cubic-bezier(.2,.9,.3,1)}
.detail-cta-btn>*{position:relative;z-index:1}
.detail-cta-btn:hover::before{transform:translateX(0)}
.detail-cta-btn:hover{transform:translateY(-2px);box-shadow:0 4px 0 var(--ink);border-color:var(--accent)}

/* === RESEARCH PANEL === */
.research-panel{position:relative}
.research-toggle-row{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px;flex-wrap:wrap}
.research-for-lbl{font-size:11px;letter-spacing:0.14em;color:var(--muted);text-transform:uppercase;font-weight:600}
.research-goal-toggle{display:inline-flex;gap:4px;background:var(--paper);padding:4px;border:1.5px solid var(--ink)}
.rgt-btn{padding:7px 14px;background:transparent;border:none;font-family:'Anton',sans-serif;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;color:var(--ink-soft);transition:all .2s ease}
.rgt-btn:hover{color:var(--ink)}
.rgt-btn.active{background:var(--ink);color:var(--bg)}

.research-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:16px}
.rs-card{padding:18px 10px;background:var(--ink);color:var(--bg);text-align:center;border-left:3px solid var(--accent);transition:transform .3s cubic-bezier(.34,1.56,.64,1), box-shadow .3s ease}
.rs-card:hover{transform:translateY(-3px);box-shadow:0 6px 0 var(--accent)}
.rs-num{font-family:'Anton',sans-serif;font-size:24px;letter-spacing:0.02em;color:var(--bg);line-height:1;margin-bottom:5px}
.rs-lbl{font-family:'Inter',sans-serif;font-size:9px;letter-spacing:0.18em;color:var(--accent);font-weight:700;text-transform:uppercase}

.research-meta{padding:14px;background:var(--paper);border-left:3px solid var(--accent);font-size:13px;line-height:1.5;color:var(--ink-soft)}
.research-meta .rm-row{margin-bottom:4px}
.research-meta .rm-row:last-child{margin-bottom:0}
.research-meta b{color:var(--ink)}
.rm-lbl{color:var(--muted);font-size:11px;letter-spacing:0.08em;text-transform:uppercase;font-weight:600}

/* === MUSCLE ACTIVATION BARS === */
.muscle-intro{font-size:13px;color:var(--ink-soft);margin-bottom:14px}
.muscle-bars{display:grid;gap:12px}
.muscle-row{display:grid;grid-template-columns:1fr 90px;gap:14px;align-items:center}
.muscle-info{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:4px;grid-column:1;grid-row:1}
.muscle-name{font-family:'Anton',sans-serif;font-size:13px;letter-spacing:0.05em;text-transform:uppercase;color:var(--ink)}
.muscle-pct{font-family:'Anton',sans-serif;font-size:14px;color:var(--accent);letter-spacing:0.02em}
.muscle-bar{grid-column:1;grid-row:2;height:8px;background:var(--paper);border:1.5px solid var(--ink);position:relative;overflow:hidden}
.muscle-fill{height:100%;background:linear-gradient(90deg, var(--accent) 0%, #ff6633 100%);width:0;animation:muscleBarFill 0.8s cubic-bezier(.2,.9,.3,1) forwards}
@keyframes muscleBarFill{from{width:0}to{width:var(--w)}}
.muscle-tag{grid-column:2;grid-row:1 / 3;display:flex;align-items:center;justify-content:center;padding:6px 10px;background:var(--ink);color:var(--bg);font-family:'Anton',sans-serif;font-size:9px;letter-spacing:0.14em;text-transform:uppercase;border-left:3px solid var(--accent);text-align:center;line-height:1.1}

.research-fact .rf-text{font-size:14px;line-height:1.6;color:var(--ink);font-style:italic;border-left:3px solid var(--accent);padding-left:16px;margin-bottom:10px}
.research-fact .rf-cite{font-size:11px;color:var(--muted);letter-spacing:0.04em}
.research-fact .rf-cite b{color:var(--ink);letter-spacing:0.1em}
.research-fact .rf-cite i{color:var(--muted)}

@media (max-width:600px){
  .research-grid{grid-template-columns:1fr 1fr;gap:6px}
  .rs-card{padding:14px 8px}
  .rs-num{font-size:18px}
  .muscle-row{grid-template-columns:1fr 60px;gap:8px}
  .muscle-tag{font-size:8px;padding:4px 6px}
}
.detail-cta-btn .arrow{font-family:'Instrument Serif',serif;font-style:italic;font-size:22px;transition:transform .25s ease}
.detail-cta-btn:hover .arrow{transform:translateX(6px)}

/* PHASE ANIMATION VIEWER — premium */

/* === 3D VIEWER STYLES === */
.phase-viewer-wrap.is-3d{background:#000}
.phase-viewer-3d{height:420px !important;background:radial-gradient(ellipse at center,#1f1f1f 0%,#000 80%) !important;position:relative;overflow:hidden}
.threed-canvas-host{position:absolute;inset:0;width:100%;height:100%}
.threed-canvas-host canvas{display:block;width:100% !important;height:100% !important}
.threed-badge{position:absolute;top:12px;left:14px;font-family:'Anton',sans-serif;font-size:10px;letter-spacing:0.22em;color:rgba(255,45,0,0.95);background:rgba(0,0,0,0.5);padding:4px 9px;border:1px solid rgba(255,45,0,0.4);z-index:5;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}

.phase-controls-3d{padding:14px 18px;display:flex;gap:14px;align-items:center}
.phase-play-btn{width:38px;height:38px;border:none;background:var(--accent);color:#fff;font-size:13px;cursor:pointer;flex-shrink:0;transition:transform .2s cubic-bezier(.2,.9,.3,1), background .2s ease;display:flex;align-items:center;justify-content:center}
.phase-play-btn:hover{transform:scale(1.06);background:#ff4500}
.phase-play-btn:active{transform:scale(0.96)}
.phase-scrub{flex:1;-webkit-appearance:none;appearance:none;height:6px;background:#2a2a2a;outline:none;cursor:pointer;border-radius:0}
.phase-scrub::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;background:var(--accent);cursor:pointer;border-radius:50%;border:2px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,0.4)}
.phase-scrub::-moz-range-thumb{width:18px;height:18px;background:var(--accent);cursor:pointer;border:2px solid #fff;border-radius:50%;box-shadow:0 2px 6px rgba(0,0,0,0.4)}
.phase-scrub:hover{background:#3a3a3a}
.phase-controls-3d .phase-label{min-width:100px;text-align:right}

@media (max-width:880px){
  .phase-viewer-3d{height:340px !important}
  .phase-controls-3d{padding:12px 14px;gap:10px}
  .phase-play-btn{width:34px;height:34px}
  .phase-controls-3d .phase-label{font-size:11px;min-width:80px}
}

.phase-viewer-wrap{margin-bottom:32px;background:var(--ink);padding:0;border:2px solid var(--ink);overflow:hidden;position:relative;transform-style:preserve-3d;transition:transform .45s cubic-bezier(.2,.9,.3,1), box-shadow .45s ease;will-change:transform;box-shadow:0 12px 32px rgba(0,0,0,0.18)}
.phase-viewer-wrap:hover{transform:perspective(1200px) translateY(-4px) rotateX(2deg);box-shadow:0 28px 56px rgba(0,0,0,0.3), 0 0 60px rgba(255,45,0,0.15)}
.phase-viewer-wrap::before{content:"GYMcheck™ MOTION ANALYSIS";position:absolute;top:10px;right:14px;font-family:'Anton',sans-serif;font-size:9px;letter-spacing:0.24em;color:rgba(255,45,0,0.7);z-index:5;mix-blend-mode:screen}
