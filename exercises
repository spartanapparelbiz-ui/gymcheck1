<script type="module">
/* ============== THREE.JS 3D ANIMATION SYSTEM ==============
 * Big 4 lifts only (Squat, Bench, Deadlift, OHP).
 * Procedural figure with proper anatomy + form-accurate keyframes.
 * Self-paced scrubber with play/pause.
 */
import * as THREE from 'three';

// === FIGURE FACTORY ===
function createFigure(){
  const root = new THREE.Group();
  const skinMat = new THREE.MeshStandardMaterial({ color: 0xd4a890, roughness: 0.7, metalness: 0.05 });
  const muscleMat = new THREE.MeshStandardMaterial({ color: 0xc47860, roughness: 0.6, metalness: 0.05 });

  // Head
  const head = new THREE.Mesh(new THREE.SphereGeometry(0.12, 24, 16), skinMat);
  head.position.y = 1.72;
  head.scale.set(0.9, 1.1, 0.95);
  root.add(head);

  // Neck
  const neck = new THREE.Mesh(new THREE.CylinderGeometry(0.055, 0.07, 0.08, 12), skinMat);
  neck.position.y = 1.58;
  root.add(neck);

  // Torso group (pivots from hips for tilt)
  const torsoGroup = new THREE.Group();
  torsoGroup.position.y = 1.25;
  root.add(torsoGroup);

  const chest = new THREE.Mesh(new THREE.CapsuleGeometry(0.18, 0.18, 8, 16), muscleMat);
  chest.scale.set(1.4, 1, 0.7);
  chest.position.y = 0.18;
  torsoGroup.add(chest);

  const waist = new THREE.Mesh(new THREE.CapsuleGeometry(0.13, 0.1, 8, 16), muscleMat);
  waist.scale.set(1.3, 1, 0.7);
  waist.position.y = -0.05;
  torsoGroup.add(waist);

  const hips = new THREE.Mesh(new THREE.SphereGeometry(0.16, 16, 12), muscleMat);
  hips.scale.set(1.3, 0.6, 0.85);
  hips.position.y = -0.2;
  torsoGroup.add(hips);

  function makeArm(side){
    const armRoot = new THREE.Group();
    armRoot.position.set(side * 0.22, 1.45, 0);
    const delt = new THREE.Mesh(new THREE.SphereGeometry(0.08, 16, 12), muscleMat);
    armRoot.add(delt);
    const upperPivot = new THREE.Group();
    armRoot.add(upperPivot);
    const upper = new THREE.Mesh(new THREE.CapsuleGeometry(0.055, 0.22, 4, 12), muscleMat);
    upper.position.y = -0.14;
    upperPivot.add(upper);
    const elbowPivot = new THREE.Group();
    elbowPivot.position.y = -0.27;
    upperPivot.add(elbowPivot);
    const forearm = new THREE.Mesh(new THREE.CapsuleGeometry(0.045, 0.2, 4, 12), muscleMat);
    forearm.position.y = -0.12;
    elbowPivot.add(forearm);
    const hand = new THREE.Mesh(new THREE.SphereGeometry(0.05, 12, 8), skinMat);
    hand.scale.set(1, 1.3, 0.7);
    hand.position.y = -0.25;
    elbowPivot.add(hand);
    armRoot.userData.shoulder = upperPivot;
    armRoot.userData.elbow = elbowPivot;
    return armRoot;
  }

  const armL = makeArm(-1);
  const armR = makeArm(1);
  root.add(armL);
  root.add(armR);

  function makeLeg(side){
    const legRoot = new THREE.Group();
    legRoot.position.set(side * 0.1, 1.02, 0);
    const hipPivot = new THREE.Group();
    legRoot.add(hipPivot);
    const thigh = new THREE.Mesh(new THREE.CapsuleGeometry(0.085, 0.34, 6, 12), muscleMat);
    thigh.position.y = -0.21;
    hipPivot.add(thigh);
    const kneePivot = new THREE.Group();
    kneePivot.position.y = -0.42;
    hipPivot.add(kneePivot);
    const calf = new THREE.Mesh(new THREE.CapsuleGeometry(0.07, 0.32, 6, 12), muscleMat);
    calf.position.y = -0.2;
    kneePivot.add(calf);
    const foot = new THREE.Mesh(new THREE.BoxGeometry(0.1, 0.06, 0.22), skinMat);
    foot.position.set(0, -0.4, 0.06);
    kneePivot.add(foot);
    legRoot.userData.hip = hipPivot;
    legRoot.userData.knee = kneePivot;
    return legRoot;
  }

  const legL = makeLeg(-1);
  const legR = makeLeg(1);
  root.add(legL);
  root.add(legR);

  root.userData.joints = {
    torso: torsoGroup,
    shoulderL: armL.userData.shoulder,
    shoulderR: armR.userData.shoulder,
    elbowL: armL.userData.elbow,
    elbowR: armR.userData.elbow,
    hipL: legL.userData.hip,
    hipR: legR.userData.hip,
    kneeL: legL.userData.knee,
    kneeR: legR.userData.knee,
  };

  return root;
}

function createBarbell(){
  const group = new THREE.Group();
  const barMat = new THREE.MeshStandardMaterial({ color: 0x666666, roughness: 0.35, metalness: 0.9 });
  const plateMat = new THREE.MeshStandardMaterial({ color: 0x0a0a0a, roughness: 0.6, metalness: 0.3 });
  const bar = new THREE.Mesh(new THREE.CylinderGeometry(0.02, 0.02, 1.4, 16), barMat);
  bar.rotation.z = Math.PI / 2;
  group.add(bar);
  for (let side of [-1, 1]) {
    for (let i = 0; i < 2; i++) {
      const plate = new THREE.Mesh(new THREE.CylinderGeometry(0.16, 0.16, 0.04, 24), plateMat);
      plate.rotation.z = Math.PI / 2;
      plate.position.x = side * (0.55 + i * 0.05);
      group.add(plate);
    }
    const ring = new THREE.Mesh(new THREE.TorusGeometry(0.15, 0.012, 8, 24), new THREE.MeshStandardMaterial({ color: 0xff2d00 }));
    ring.rotation.y = Math.PI / 2;
    ring.position.x = side * 0.625;
    group.add(ring);
  }
  return group;
}

function createBench(){
  const benchMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.7 });
  const padMat = new THREE.MeshStandardMaterial({ color: 0x0a0a0a, roughness: 0.9 });
  const group = new THREE.Group();
  const pad = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.06, 1.3), padMat);
  pad.position.y = 0.4;
  group.add(pad);
  for (let z of [-0.5, 0.5]) {
    const leg = new THREE.Mesh(new THREE.BoxGeometry(0.08, 0.4, 0.08), benchMat);
    leg.position.set(0, 0.18, z);
    group.add(leg);
    const brace = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.04, 0.08), benchMat);
    brace.position.set(0, 0.02, z);
    group.add(brace);
  }
  return group;
}

// === FORM-ACCURATE LIFT POSES ===
function lerp(a, b, t){ return a + (b - a) * t; }
function easeInOut(t){ return t < 0.5 ? 2*t*t : 1 - Math.pow(-2*t+2, 2)/2; }

function squatPose(t){
  const phase = t < 0.5 ? easeInOut(t * 2) : easeInOut((1 - t) * 2);
  return {
    rootY: lerp(0, -0.38, phase),
    torsoTilt: lerp(0, -0.4, phase),
    hipPivot: lerp(0, -1.3, phase),
    kneePivot: lerp(0, 1.7, phase),
    elbowBend: -1.4,
    barY: lerp(1.55, 1.17, phase),
    phase: t < 0.05 ? 'STAND' : t < 0.45 ? 'DESCENT' : t < 0.55 ? 'BOTTOM' : t < 0.95 ? 'DRIVE UP' : 'LOCKOUT'
  };
}

function benchPose(t){
  const phase = t < 0.5 ? easeInOut(t * 2) : easeInOut((1 - t) * 2);
  return {
    elbowBend: lerp(0, 1.9, phase),
    shoulderRot: lerp(0, 0.4, phase),
    barY: lerp(1.05, 0.78, phase),
    phase: t < 0.05 ? 'UNRACK' : t < 0.45 ? 'LOWER' : t < 0.55 ? 'TOUCH CHEST' : t < 0.95 ? 'PRESS' : 'LOCKOUT'
  };
}

function deadliftPose(t){
  const phase = t < 0.5 ? easeInOut(t * 2) : easeInOut((1 - t) * 2);
  return {
    rootY: lerp(-0.38, 0, phase),
    torsoTilt: lerp(-1.0, 0, phase),
    hipPivot: lerp(-1.5, 0, phase),
    kneePivot: lerp(0.9, 0, phase),
    barY: lerp(0.18, 1.05, phase),
    barZ: lerp(0.15, 0, phase),
    phase: t < 0.05 ? 'SETUP' : t < 0.45 ? 'LIFT OFF' : t < 0.55 ? 'PAST KNEES' : t < 0.95 ? 'LOCKOUT' : 'LOWERING'
  };
}

function ohpPose(t){
  const phase = t < 0.5 ? easeInOut(t * 2) : easeInOut((1 - t) * 2);
  return {
    elbowBend: lerp(2.4, 0.1, phase),
    shoulderRot: lerp(0.3, -2.7, phase),
    barY: lerp(1.46, 2.05, phase),
    phase: t < 0.05 ? 'RACK' : t < 0.45 ? 'DRIVE UP' : t < 0.55 ? 'OVERHEAD' : t < 0.95 ? 'LOWER' : 'RACK'
  };
}

// === SCENE STATE ===
let currentScene = null;
let animationFrame = null;
let isPlaying = false;
let scrubT = 0;

function applyPose(scene, t){
  const figure = scene.figure;
  const joints = figure.userData.joints;
  let pose;

  if (scene.exerciseType === 'squat') {
    pose = squatPose(t);
    figure.position.y = pose.rootY;
    figure.rotation.x = 0;
    joints.torso.rotation.x = pose.torsoTilt;
    joints.hipL.rotation.x = pose.hipPivot;
    joints.hipR.rotation.x = pose.hipPivot;
    joints.kneeL.rotation.x = pose.kneePivot;
    joints.kneeR.rotation.x = pose.kneePivot;
    joints.shoulderL.rotation.x = -2.3;
    joints.shoulderR.rotation.x = -2.3;
    joints.shoulderL.rotation.z = 0.3;
    joints.shoulderR.rotation.z = -0.3;
    joints.elbowL.rotation.x = pose.elbowBend;
    joints.elbowR.rotation.x = pose.elbowBend;
    if (scene.bar) scene.bar.position.set(0, pose.barY + pose.rootY, -0.05);
    return pose;
  }
  if (scene.exerciseType === 'deadlift') {
    pose = deadliftPose(t);
    figure.position.y = pose.rootY;
    figure.rotation.x = 0;
    joints.torso.rotation.x = pose.torsoTilt;
    joints.hipL.rotation.x = pose.hipPivot;
    joints.hipR.rotation.x = pose.hipPivot;
    joints.kneeL.rotation.x = pose.kneePivot;
    joints.kneeR.rotation.x = pose.kneePivot;
    joints.shoulderL.rotation.x = 0;
    joints.shoulderR.rotation.x = 0;
    joints.shoulderL.rotation.z = 0.05;
    joints.shoulderR.rotation.z = -0.05;
    joints.elbowL.rotation.x = 0;
    joints.elbowR.rotation.x = 0;
    if (scene.bar) scene.bar.position.set(0, pose.barY, pose.barZ);
    return pose;
  }
  if (scene.exerciseType === 'bench') {
    pose = benchPose(t);
    figure.position.set(0, 0.5, 0);
    figure.rotation.x = -Math.PI / 2;
    joints.torso.rotation.x = 0;
    joints.shoulderL.rotation.x = -Math.PI / 2 + pose.shoulderRot;
    joints.shoulderR.rotation.x = -Math.PI / 2 + pose.shoulderRot;
    joints.shoulderL.rotation.z = 0.2;
    joints.shoulderR.rotation.z = -0.2;
    joints.elbowL.rotation.x = pose.elbowBend;
    joints.elbowR.rotation.x = pose.elbowBend;
    joints.hipL.rotation.x = 0.3;
    joints.hipR.rotation.x = 0.3;
    joints.kneeL.rotation.x = 0.6;
    joints.kneeR.rotation.x = 0.6;
    if (scene.bar) scene.bar.position.set(0, pose.barY, 0);
    return pose;
  }
  if (scene.exerciseType === 'ohp') {
    pose = ohpPose(t);
    figure.position.y = 0;
    figure.rotation.x = 0;
    joints.torso.rotation.x = 0;
    joints.shoulderL.rotation.x = pose.shoulderRot;
    joints.shoulderR.rotation.x = pose.shoulderRot;
    joints.shoulderL.rotation.z = 0.15;
    joints.shoulderR.rotation.z = -0.15;
    joints.elbowL.rotation.x = pose.elbowBend;
    joints.elbowR.rotation.x = pose.elbowBend;
    joints.hipL.rotation.x = 0;
    joints.hipR.rotation.x = 0;
    joints.kneeL.rotation.x = 0.05;
    joints.kneeR.rotation.x = 0.05;
    if (scene.bar) scene.bar.position.set(0, pose.barY, 0);
    return pose;
  }
  return { phase: '?' };
}

function makeScene(container, exerciseType){
  const w = container.clientWidth;
  const h = container.clientHeight;

  const scene = new THREE.Scene();
  scene.background = null;
  scene.fog = new THREE.Fog(0x000000, 4, 8);

  const camera = new THREE.PerspectiveCamera(35, w/h, 0.1, 50);
  camera.position.set(2.5, 1.4, 3.2);
  camera.lookAt(0, 1.0, 0);

  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
  renderer.setSize(w, h);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  container.appendChild(renderer.domElement);

  const keyLight = new THREE.DirectionalLight(0xffe0d0, 1.4);
  keyLight.position.set(2, 3, 2);
  keyLight.castShadow = true;
  keyLight.shadow.mapSize.set(1024, 1024);
  scene.add(keyLight);
  const fillLight = new THREE.DirectionalLight(0x6080ff, 0.4);
  fillLight.position.set(-2, 1, 1);
  scene.add(fillLight);
  const rimLight = new THREE.DirectionalLight(0xff2d00, 0.6);
  rimLight.position.set(-1, 2, -2);
  scene.add(rimLight);
  scene.add(new THREE.AmbientLight(0x444466, 0.3));

  const floor = new THREE.Mesh(
    new THREE.PlaneGeometry(8, 8),
    new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.9 })
  );
  floor.rotation.x = -Math.PI / 2;
  floor.receiveShadow = true;
  scene.add(floor);

  const figure = createFigure();
  figure.traverse(c => { if (c.isMesh) { c.castShadow = true; c.receiveShadow = true; }});
  scene.add(figure);

  let bar = null;
  let bench = null;
  if (exerciseType === 'squat' || exerciseType === 'deadlift' || exerciseType === 'ohp' || exerciseType === 'bench') {
    bar = createBarbell();
    scene.add(bar);
  }
  if (exerciseType === 'bench') {
    bench = createBench();
    scene.add(bench);
  }

  return { scene, camera, renderer, figure, bar, bench, exerciseType, container };
}

// === PUBLIC API ===
window.init3DAnimation = function(exerciseType){
  destroy3DAnimation();
  const host = document.getElementById('threedHost');
  if (!host) return;
  // Wait for layout
  if (host.clientWidth === 0) {
    setTimeout(() => window.init3DAnimation(exerciseType), 50);
    return;
  }
  currentScene = makeScene(host, exerciseType);
  scrubT = 0;
  isPlaying = false;
  applyPose(currentScene, 0);

  // Wire scrubber
  const scrub = document.getElementById('phaseScrub');
  const playBtn = document.getElementById('phasePlayBtn');
  const label = document.getElementById('phaseLabel');
  if (scrub) {
    scrub.value = 0;
    scrub.addEventListener('input', () => {
      scrubT = parseInt(scrub.value) / 1000;
      const pose = applyPose(currentScene, scrubT);
      if (label && pose && pose.phase) label.textContent = pose.phase;
    });
  }
  if (playBtn) {
    playBtn.textContent = '▶';
    playBtn.addEventListener('click', () => {
      isPlaying = !isPlaying;
      playBtn.textContent = isPlaying ? '⏸' : '▶';
    });
  }

  // Render loop
  function tick(){
    if (!currentScene) return;
    if (isPlaying) {
      scrubT += 0.0035;
      if (scrubT > 1) scrubT = 0;
      if (scrub) scrub.value = Math.round(scrubT * 1000);
      const pose = applyPose(currentScene, scrubT);
      if (label && pose && pose.phase) label.textContent = pose.phase;
    }
    currentScene.renderer.render(currentScene.scene, currentScene.camera);
    animationFrame = requestAnimationFrame(tick);
  }
  tick();

  // Handle resize
  window._3dResizeHandler = () => {
    if (!currentScene) return;
    const w = currentScene.container.clientWidth;
    const h = currentScene.container.clientHeight;
    currentScene.camera.aspect = w / h;
    currentScene.camera.updateProjectionMatrix();
    currentScene.renderer.setSize(w, h);
  };
  window.addEventListener('resize', window._3dResizeHandler);
};

window.destroy3DAnimation = function(){
  if (animationFrame) cancelAnimationFrame(animationFrame);
  animationFrame = null;
  isPlaying = false;
  if (window._3dResizeHandler) {
    window.removeEventListener('resize', window._3dResizeHandler);
    window._3dResizeHandler = null;
  }
  if (currentScene) {
    if (currentScene.renderer) {
      currentScene.renderer.dispose();
      if (currentScene.renderer.domElement && currentScene.renderer.domElement.parentNode) {
        currentScene.renderer.domElement.parentNode.removeChild(currentScene.renderer.domElement);
      }
    }
    currentScene.scene.traverse(o => {
      if (o.geometry) o.geometry.dispose();
      if (o.material) {
        if (Array.isArray(o.material)) o.material.forEach(m => m.dispose());
        else o.material.dispose();
      }
    });
    currentScene = null;
  }
};
