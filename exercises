/* ============== PHASE ANIMATION SYSTEM ============== */
// Each exercise gets 4 SVG frames representing the phases of the lift.
// We pick the right frames based on the exercise category + name.

function buildPhaseAnimation(ex){
  const frames = getPhaseFramesForExercise(ex);
  return `
    <svg class="phase-svg" viewBox="0 0 200 240" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="bgGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#1a1a1a"/>
          <stop offset="1" stop-color="#0d0d0d"/>
        </linearGradient>
        <pattern id="floorPattern" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <rect width="20" height="20" fill="#0a0a0a"/>
          <line x1="0" y1="0" x2="20" y2="0" stroke="#222" stroke-width="0.5"/>
          <line x1="0" y1="0" x2="0" y2="20" stroke="#222" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="200" height="240" fill="url(#bgGrad)"/>
      <rect x="0" y="200" width="200" height="40" fill="url(#floorPattern)"/>
      ${frames.map((frame, i) => `
        <g class="phase-frame" data-frame="${i}" opacity="${i === 0 ? 1 : 0}">
          ${frame.svg}
        </g>
      `).join('')}
    </svg>
  `;
}

function initPhaseAnimation(ex){
  const viewer = document.getElementById('phaseViewer');
  const dotsEl = document.getElementById('phaseDots');
  const labelEl = document.getElementById('phaseLabel');
  if (!viewer || !dotsEl || !labelEl) return;

  const frames = getPhaseFramesForExercise(ex);

  // Build dot navigation
  dotsEl.innerHTML = frames.map((f, i) => `<button class="phase-dot${i === 0 ? ' active' : ''}" data-i="${i}" aria-label="Phase ${i+1}"></button>`).join('');

  let currentFrame = 0;
  let timer = null;

  function showFrame(i){
    const frameEls = viewer.querySelectorAll('.phase-frame');
    frameEls.forEach((el, idx) => {
      el.setAttribute('opacity', idx === i ? '1' : '0');
    });
    dotsEl.querySelectorAll('.phase-dot').forEach((d, idx) => {
      d.classList.toggle('active', idx === i);
    });
    labelEl.textContent = `PHASE ${i+1}: ${frames[i].label}`;
    currentFrame = i;
  }

  function nextFrame(){
    showFrame((currentFrame + 1) % frames.length);
  }

  // Auto-cycle every 1.6s
  timer = setInterval(nextFrame, 1600);

  // Click dots to jump
  dotsEl.querySelectorAll('.phase-dot').forEach(dot => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      showFrame(parseInt(dot.dataset.i));
      // Resume after 4s of inactivity
      setTimeout(() => {
        timer = setInterval(nextFrame, 1600);
      }, 4000);
    });
  });

  // Cleanup when panel closes
  window._currentPhaseTimer = timer;
}

// Stop animation when closing panel
const origCloseDetail = window.closeDetail;
window.closeDetail = function(){
  if (window._currentPhaseTimer) clearInterval(window._currentPhaseTimer);
  destroy3DAnimation();
  if (origCloseDetail) origCloseDetail.apply(this, arguments);
};

