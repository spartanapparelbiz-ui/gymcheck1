// === ANATOMICAL BODY (VERTICAL) ===
// Builds a properly-proportioned standing body with adjustable bends.
// Uses paths for muscle shaping rather than stick lines.
function anatomicalBody(opts){
  const C = FIG_COLORS;
  const cx = 100;
  const o = opts;

  // Tilt the torso based on torsoTilt (degrees, negative = forward lean)
  const tiltRad = (o.torsoTilt || 0) * Math.PI / 180;
  const torsoLen = o.torsoBottom - o.torsoTop;
  const torsoTopX = cx + o.leanX;
  const torsoTopY = o.torsoTop;
  const torsoBottomX = torsoTopX + Math.sin(tiltRad) * torsoLen;
  const torsoBottomY = torsoTopY + Math.cos(tiltRad) * torsoLen;
  const torsoMidX = (torsoTopX + torsoBottomX) / 2;
  const torsoMidY = (torsoTopY + torsoBottomY) / 2;

  // Shoulder positions (left & right offset from torso top)
  const shoulderL_X = torsoTopX - o.shoulderW/2;
  const shoulderL_Y = o.shoulderY + (torsoTopY - o.torsoTop);
  const shoulderR_X = torsoTopX + o.shoulderW/2;
  const shoulderR_Y = o.shoulderY + (torsoTopY - o.torsoTop);

  // Hip positions
  const hipL_X = torsoBottomX - o.hipW/2;
  const hipR_X = torsoBottomX + o.hipW/2;
  const hipY = torsoBottomY;

  // Knees (bent inward when squatting)
  const thighLen = o.thighEnd - o.hipY;
  const kneeL_X = hipL_X - 2 - (o.kneeBendL || 0) * 0.3;
  const kneeR_X = hipR_X + 2 + (o.kneeBendR || 0) * 0.3;
  const kneeL_Y = hipY + thighLen - (o.kneeBendL || 0) * 0.4;
  const kneeR_Y = hipY + thighLen - (o.kneeBendR || 0) * 0.4;

  // Feet
  const footL_X = hipL_X - 6;
  const footR_X = hipR_X + 6;
  const footY = o.calfEnd;

  // Determine muscle highlights
  const active = o.active || '';
  const activeQuads = active.includes('quads');
  const activeGlutes = active.includes('glutes');
  const activeHams = active.includes('hams');
  const activeBack = active.includes('back');
  const activeChest = active.includes('chest');
  const activeShoulders = active.includes('shoulders');
  const activeLats = active.includes('lats');
  const activeBis = active.includes('bis');
  const activeTris = active.includes('tris');
  const activeTraps = active.includes('traps');
  const fullBody = active.includes('full');

  const skinColor = fullBody ? C.active : C.body;
  const skinShade = fullBody ? C.activeShade : C.bodyShade;

  // Head (with neck attachment)
  const head = `
    <ellipse cx="${torsoTopX}" cy="${o.headCy}" rx="11" ry="13" fill="${skinColor}"/>
    <ellipse cx="${torsoTopX-3}" cy="${o.headCy-2}" rx="3" ry="4" fill="${skinShade}" opacity="0.5"/>
  `;

  // Neck (small line connecting head to torso)
  const neckColor = (activeTraps || activeShoulders) ? C.active : skinColor;
  const neck = `
    <rect x="${torsoTopX-5}" y="${o.headCy+10}" width="10" height="${o.shoulderY - o.headCy - 10}" fill="${neckColor}" rx="2"/>
  `;

  // TORSO — built as a path with shoulder + lat + waist taper
  // Going clockwise: left shoulder → right shoulder → right lat → right hip → left hip → left lat → close
  const torsoPath = `
    M ${shoulderL_X},${shoulderL_Y}
    Q ${torsoTopX-o.shoulderW/2 - 4},${shoulderL_Y + 8} ${torsoTopX-o.shoulderW/2 + 4},${torsoMidY-6}
    L ${hipL_X-2},${hipY-4}
    Q ${hipL_X+2},${hipY+2} ${hipR_X-2},${hipY+2}
    Q ${hipR_X-2},${hipY+2} ${hipR_X+2},${hipY-4}
    L ${torsoTopX+o.shoulderW/2 - 4},${torsoMidY-6}
    Q ${torsoTopX+o.shoulderW/2 + 4},${shoulderR_Y + 8} ${shoulderR_X},${shoulderR_Y}
    Q ${torsoTopX},${shoulderL_Y-4} ${shoulderL_X},${shoulderL_Y}
    Z
  `;
  const chestColor = activeChest ? C.active : skinColor;
  const torsoShadeColor = activeBack ? C.active : skinShade;

  let torso = `
    <path d="${torsoPath}" fill="${chestColor}"/>
  `;
  // Chest definition line
  if (!activeBack) {
    torso += `<line x1="${torsoTopX}" y1="${shoulderL_Y + 6}" x2="${torsoTopX}" y2="${torsoMidY + 2}" stroke="${skinShade}" stroke-width="1.5" opacity="0.7"/>`;
  }
  // Ab definition
  if (activeChest || active.includes('core')) {
    torso += `
      <line x1="${torsoTopX-7}" y1="${torsoMidY+4}" x2="${torsoTopX+7}" y2="${torsoMidY+4}" stroke="${skinShade}" stroke-width="1" opacity="0.4"/>
      <line x1="${torsoTopX-6}" y1="${torsoMidY+12}" x2="${torsoTopX+6}" y2="${torsoMidY+12}" stroke="${skinShade}" stroke-width="1" opacity="0.4"/>
    `;
  }

  // ARMS — bicep and forearm as separate shapes for definition
  let arms = '';
  const armColor = (activeBis || activeChest || activeTris) ? C.active : skinColor;
  switch(o.armPose){
    case 'down':
      arms = anatomicalArm(shoulderL_X, shoulderL_Y, shoulderL_X-4, torsoMidY+10, shoulderL_X-6, torsoBottomY+5, skinColor, activeBis ? C.active : null)
           + anatomicalArm(shoulderR_X, shoulderR_Y, shoulderR_X+4, torsoMidY+10, shoulderR_X+6, torsoBottomY+5, skinColor, activeBis ? C.active : null);
      break;
    case 'gripBack':
      arms = anatomicalArm(shoulderL_X, shoulderL_Y, shoulderL_X-12, shoulderL_Y+10, shoulderL_X-18, shoulderL_Y-2, skinColor, null)
           + anatomicalArm(shoulderR_X, shoulderR_Y, shoulderR_X+12, shoulderR_Y+10, shoulderR_X+18, shoulderR_Y-2, skinColor, null);
      break;
    case 'gripFront':
      arms = anatomicalArm(shoulderL_X, shoulderL_Y, shoulderL_X-3, torsoMidY+15, shoulderL_X-2, torsoBottomY+8, skinColor, null)
           + anatomicalArm(shoulderR_X, shoulderR_Y, shoulderR_X+3, torsoMidY+15, shoulderR_X+2, torsoBottomY+8, skinColor, null);
      break;
    case 'reachDown':
      arms = anatomicalArm(shoulderL_X, shoulderL_Y, shoulderL_X-2, shoulderL_Y+30, shoulderL_X-12, shoulderL_Y+60, skinColor, null)
           + anatomicalArm(shoulderR_X, shoulderR_Y, shoulderR_X+2, shoulderR_Y+30, shoulderR_X+12, shoulderR_Y+60, skinColor, null);
      break;
    case 'rackPosition':
      arms = anatomicalArm(shoulderL_X, shoulderL_Y, shoulderL_X-10, shoulderL_Y+10, shoulderL_X-4, shoulderL_Y-6, activeShoulders ? C.active : skinColor, null)
           + anatomicalArm(shoulderR_X, shoulderR_Y, shoulderR_X+10, shoulderR_Y+10, shoulderR_X+4, shoulderR_Y-6, activeShoulders ? C.active : skinColor, null);
      break;
    case 'pressDrive':
      arms = anatomicalArm(shoulderL_X, shoulderL_Y, shoulderL_X-8, shoulderL_Y-15, shoulderL_X-2, shoulderL_Y-32, C.active, null)
           + anatomicalArm(shoulderR_X, shoulderR_Y, shoulderR_X+8, shoulderR_Y-15, shoulderR_X+2, shoulderR_Y-32, C.active, null);
      break;
    case 'overhead':
      arms = anatomicalArm(shoulderL_X, shoulderL_Y, shoulderL_X-4, shoulderL_Y-25, shoulderL_X-6, shoulderL_Y-50, activeShoulders ? C.active : skinColor, null)
           + anatomicalArm(shoulderR_X, shoulderR_Y, shoulderR_X+4, shoulderR_Y-25, shoulderR_X+6, shoulderR_Y-50, activeShoulders ? C.active : skinColor, null);
      break;
    case 'pressLower':
      arms = anatomicalArm(shoulderL_X, shoulderL_Y, shoulderL_X-9, shoulderL_Y-8, shoulderL_X-4, shoulderL_Y-22, skinColor, null)
           + anatomicalArm(shoulderR_X, shoulderR_Y, shoulderR_X+9, shoulderR_Y-8, shoulderR_X+4, shoulderR_Y-22, skinColor, null);
      break;
    case 'overheadGrip':
      arms = anatomicalArm(shoulderL_X, shoulderL_Y, shoulderL_X-6, shoulderL_Y-20, shoulderL_X-14, shoulderL_Y-44, activeLats ? C.active : skinColor, null)
           + anatomicalArm(shoulderR_X, shoulderR_Y, shoulderR_X+6, shoulderR_Y-20, shoulderR_X+14, shoulderR_Y-44, activeLats ? C.active : skinColor, null);
      break;
    case 'pullingUp':
      arms = anatomicalArm(shoulderL_X, shoulderL_Y, shoulderL_X-15, shoulderL_Y-10, shoulderL_X-18, shoulderL_Y-32, C.active, C.active)
           + anatomicalArm(shoulderR_X, shoulderR_Y, shoulderR_X+15, shoulderR_Y-10, shoulderR_X+18, shoulderR_Y-32, C.active, C.active);
      break;
    case 'topPullup':
      arms = anatomicalArm(shoulderL_X, shoulderL_Y, shoulderL_X-18, shoulderL_Y-4, shoulderL_X-22, shoulderL_Y-22, C.active, C.active)
           + anatomicalArm(shoulderR_X, shoulderR_Y, shoulderR_X+18, shoulderR_Y-4, shoulderR_X+22, shoulderR_Y-22, C.active, C.active);
      break;
  }

  // LEGS — quads + calves, with knees
  const quadColor = activeQuads ? C.active : skinColor;
  const hamColor = activeHams ? C.active : skinColor;
  const gluteColor = activeGlutes ? C.active : skinColor;

  // Left thigh
  const thighL = `
    <path d="M ${hipL_X-2},${hipY-2} Q ${hipL_X-6},${(hipY+kneeL_Y)/2} ${kneeL_X-2},${kneeL_Y} L ${kneeL_X+2},${kneeL_Y} Q ${hipL_X+2},${(hipY+kneeL_Y)/2} ${hipL_X+2},${hipY-2} Z" fill="${quadColor}"/>
  `;
  const thighR = `
    <path d="M ${hipR_X-2},${hipY-2} Q ${hipR_X-2},${(hipY+kneeR_Y)/2} ${kneeR_X-2},${kneeR_Y} L ${kneeR_X+2},${kneeR_Y} Q ${hipR_X+6},${(hipY+kneeR_Y)/2} ${hipR_X+2},${hipY-2} Z" fill="${quadColor}"/>
  `;

  // Calves
  const calfL = `
    <path d="M ${kneeL_X-2},${kneeL_Y} Q ${kneeL_X-6},${(kneeL_Y+footY)/2} ${footL_X-2},${footY} L ${footL_X+4},${footY} Q ${kneeL_X+1},${(kneeL_Y+footY)/2} ${kneeL_X+2},${kneeL_Y} Z" fill="${skinColor}"/>
  `;
  const calfR = `
    <path d="M ${kneeR_X-2},${kneeR_Y} Q ${kneeR_X-1},${(kneeR_Y+footY)/2} ${footR_X-4},${footY} L ${footR_X+2},${footY} Q ${kneeR_X+6},${(kneeR_Y+footY)/2} ${kneeR_X+2},${kneeR_Y} Z" fill="${skinColor}"/>
  `;

  // Knee caps
  const knees = `
    <circle cx="${kneeL_X}" cy="${kneeL_Y}" r="3" fill="${skinShade}"/>
    <circle cx="${kneeR_X}" cy="${kneeR_Y}" r="3" fill="${skinShade}"/>
  `;

  // Feet
  const feet = `
    <ellipse cx="${footL_X}" cy="${footY+2}" rx="9" ry="4" fill="${skinShade}"/>
    <ellipse cx="${footR_X}" cy="${footY+2}" rx="9" ry="4" fill="${skinShade}"/>
  `;

  return head + neck + thighL + thighR + calfL + calfR + knees + feet + torso + arms;
}

// === ANATOMICAL ARM HELPER ===
// Draws bicep (shoulder→elbow) and forearm (elbow→hand) as tapered shapes.
function anatomicalArm(shX, shY, elbowX, elbowY, handX, handY, color, accentColor){
  const bicepColor = accentColor || color;
  return `
    <path d="M ${shX-4},${shY-2} Q ${shX-6},${(shY+elbowY)/2} ${elbowX-3},${elbowY} L ${elbowX+3},${elbowY} Q ${shX+4},${(shY+elbowY)/2} ${shX+4},${shY-2} Z" fill="${bicepColor}"/>
    <path d="M ${elbowX-3},${elbowY} Q ${(elbowX+handX)/2 - 2},${(elbowY+handY)/2} ${handX-2},${handY} L ${handX+3},${handY} Q ${(elbowX+handX)/2 + 2},${(elbowY+handY)/2} ${elbowX+3},${elbowY} Z" fill="${color}"/>
    <circle cx="${elbowX}" cy="${elbowY}" r="2.5" fill="${color}" opacity="0.7"/>
    <circle cx="${handX}" cy="${handY}" r="3.5" fill="${color}"/>
  `;
}

// === ANATOMICAL BODY (HORIZONTAL — for bench/plank/etc) ===
function anatomicalBodyHorizontal(opts){
  const C = FIG_COLORS;
  const o = opts;
  const cy = 168 + (o.bodyYOffset || 0);  // base Y (lying on bench or plank)
  const isPlank = o.isPlank;

  const active = o.active || '';
  const skinColor = active.includes('full') ? C.active : C.body;
  const coreActive = active.includes('core');

  // Head (oval)
  const head = `
    <ellipse cx="${o.headX}" cy="${cy + 2}" rx="10" ry="11" fill="${skinColor}"/>
    <ellipse cx="${o.headX-2}" cy="${cy}" rx="3" ry="4" fill="${C.bodyShade}" opacity="0.4"/>
  `;
  // Neck
  const neck = `<rect x="${o.headX+8}" y="${cy-3}" width="${o.neckW}" height="10" fill="${skinColor}" rx="2"/>`;

  // TORSO — wider at shoulders, narrower at waist
  const sx = o.torsoStart;
  const ex = o.torsoEnd;
  const wTop = o.shoulderW;
  const wMid = o.shoulderW - 2;
  const torso = `
    <path d="M ${sx},${cy-wTop/2}
             Q ${sx-2},${cy} ${sx},${cy+wTop/2}
             L ${ex-10},${cy+wMid/2}
             Q ${ex+4},${cy} ${ex-10},${cy-wMid/2}
             Z" fill="${skinColor}"/>
  `;
  // Ab definition
  let abs = '';
  if (coreActive || active.includes('chest')) {
    const segments = active.includes('full') ? 4 : 3;
    for (let i = 1; i <= segments; i++) {
      const x = sx + (ex - sx) * (i / (segments + 1));
      abs += `<line x1="${x}" y1="${cy-wTop/2+4}" x2="${x}" y2="${cy+wTop/2-4}" stroke="${C.bodyShade}" stroke-width="1" opacity="0.5"/>`;
    }
    // Center line
    abs += `<line x1="${sx+5}" y1="${cy}" x2="${ex-12}" y2="${cy}" stroke="${C.bodyShade}" stroke-width="1" opacity="0.5"/>`;
  }

  // Legs
  let legs;
  if (o.legBend === 'overEdge') {
    // Bench: legs hang over edge of bench (down)
    legs = `
      <path d="M ${o.legStart-5},${cy-8} Q ${o.legStart+10},${cy-4} ${o.legStart+18},${cy+10} L ${o.legStart+30},${cy+45} L ${o.legEnd-5},${cy+45} L ${o.legEnd-5},${cy+10} Q ${o.legStart+12},${cy+6} ${o.legStart-5},${cy+2} Z" fill="${skinColor}"/>
      <path d="M ${o.legStart-5},${cy+10} Q ${o.legStart+8},${cy+14} ${o.legStart+22},${cy+25} L ${o.legStart+35},${cy+50} L ${o.legEnd-2},${cy+50} L ${o.legEnd-2},${cy+25} Q ${o.legStart+15},${cy+20} ${o.legStart-2},${cy+12} Z" fill="${C.bodyShade}" opacity="0.6"/>
    `;
  } else {
    // Extended (plank or floor)
    legs = `
      <path d="M ${o.legStart-5},${cy-6} L ${o.legEnd},${cy-3} L ${o.legEnd+8},${cy+2} L ${o.legEnd},${cy+6} L ${o.legStart-5},${cy+6} Z" fill="${skinColor}"/>
    `;
  }

  // Plank arms (forearms down on floor)
  let arms = '';
  if (isPlank) {
    // Forearms supporting body
    arms = `
      <path d="M ${sx+10},${cy-wTop/2} L ${sx+10},${cy+wTop/2+30} L ${sx+20},${cy+wTop/2+30} L ${sx+15},${cy-wTop/2} Z" fill="${active.includes('full') ? C.active : skinColor}"/>
      <ellipse cx="${sx+15}" cy="${cy+wTop/2+32}" rx="6" ry="3" fill="${C.bodyShade}"/>
    `;
  }

  return legs + torso + abs + neck + head + arms;
}


