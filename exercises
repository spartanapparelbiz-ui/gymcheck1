function getPhaseFramesForExercise(ex){
  const name = ex.name.toLowerCase();
  // Specific matches
  if (name.includes('snatch') || name.includes('clean') || name.includes('jerk') || name.includes('jump') || name.includes('thruster') || name.includes('high pull')) return FRAMES_LIB.explosive;
  if (name.includes('plank') || name.includes('crunch') || name.includes('rollout') || name.includes('twist') || name.includes('leg raise') || name.includes('pallof') || name.includes('flag') || name.includes('l-sit') || name.includes('dead bug') || name.includes('bird dog')) return FRAMES_LIB.core;
  if (name.includes('deadlift') || name === 'rdl' || name.includes('romanian') || name.includes('stiff-leg') || name.includes('good morning') || name.includes('rack pull') || name.includes('hip thrust') || name.includes('glute bridge')) return name.includes('rdl') || name.includes('romanian') || name.includes('good morning') || name.includes('stiff-leg') ? FRAMES_LIB.hinge : FRAMES_LIB.deadlift;
  if (name.includes('pull-up') || name.includes('chin-up') || name.includes('row') || name.includes('pulldown') || name.includes('curl') || name.includes('face pull') || name.includes('shrug') || name.includes('pullover')) return FRAMES_LIB.pull;
  if (name.includes('bench') || name.includes('fly') || name.includes('push-up') || name.includes('dip')) return FRAMES_LIB.bench;
  if (name.includes('press') || name.includes('raise') || name.includes('pushdown') || name.includes('skull') || name.includes('tricep')) return FRAMES_LIB.press;
  if (name.includes('squat') || name.includes('lunge') || name.includes('leg press') || name.includes('leg ext') || name.includes('leg curl') || name.includes('calf') || name.includes('step-up') || name.includes('step up')) return FRAMES_LIB.squat;
  // Cardio + other movement defaults to a simple stand-cycle
  return FRAMES_LIB.explosive;
}

