/* Smart fallback — infers research data from exercise category and muscles
 * Most lifters' "isolation" or accessory work follows established patterns:
 * Compounds = lower reps, more sets, more rest
 * Isolations = higher reps, fewer sets, less rest
 */
function getResearchFor(ex){
  const exName = typeof ex === 'string' ? ex : ex.name;
  if (RESEARCH[exName]) return RESEARCH[exName];

  // Infer from cat + muscles
  const exObj = typeof ex === 'string' ? null : ex;
  if (!exObj) return null;

  const isCompound = exObj.cat === 'big4' || exObj.cat === 'oly' ||
    (exObj.muscles && exObj.muscles.split('·').length >= 3);
  const isCore = exObj.cat === 'core';
  const isCardio = exObj.cat === 'cardio';
  const isOly = exObj.cat === 'oly';

  // Primary muscle parsing
  const muscleList = (exObj.muscles || '').split('·').map(m => m.trim()).filter(Boolean);
  const primaryMuscle = muscleList[0] || 'Mixed';

  // Generate activation profile
  const primary = { muscle: primaryMuscle, activation: isCompound ? 88 : 78 };
  const secondary = muscleList.slice(1).map((m, i) => ({
    muscle: m,
    activation: Math.max(50, 75 - i * 8)
  }));

  // Sets/reps based on movement type
  let sets, reps, rest, fact, citation;
  if (isOly) {
    sets = { strength: '5-8', hypertrophy: '4-5', endurance: '3-4', general: '4-6' };
    reps = { strength: '1-3', hypertrophy: '3-5', endurance: '5-8', general: '3-5' };
    rest = { strength: '3-5 min', hypertrophy: '2-3 min', endurance: '90s', general: '2-3 min' };
    fact = 'Olympic lifts develop power output (force × velocity). Best trained fresh, at the start of a session.';
    citation = 'Chaouachi 2014, Tricoli 2005';
  } else if (isCore) {
    sets = { strength: '3-4', hypertrophy: '3-4', endurance: '3-5', general: '3-4' };
    reps = { strength: '8-12', hypertrophy: '12-20', endurance: '20-30 or 30-60s hold', general: '15-25' };
    rest = { strength: '90s', hypertrophy: '60-90s', endurance: '30-45s', general: '60s' };
    fact = 'Core work responds best to higher rep ranges or time-under-tension holds. Train 2-3x/week with progressive overload.';
    citation = 'Schoenfeld 2015';
  } else if (isCardio) {
    sets = { strength: '3-4', hypertrophy: '3-4', endurance: '3-5', general: '3-4' };
    reps = { strength: '8-10 power', hypertrophy: '12-15', endurance: '20-30+ or interval', general: '15-25' };
    rest = { strength: '2 min', hypertrophy: '60-90s', endurance: '30-60s', general: '60s' };
    fact = 'Conditioning movements should be sequenced AFTER strength work, not before — they fatigue the CNS.';
    citation = 'Hickson 1980, Wilson 2012';
  } else if (isCompound) {
    sets = { strength: '3-5', hypertrophy: '3-4', endurance: '2-3', general: '3-4' };
    reps = { strength: '4-6', hypertrophy: '6-12', endurance: '12-15', general: '6-10' };
    rest = { strength: '3-5 min', hypertrophy: '2-3 min', endurance: '60-90s', general: '90s-2 min' };
    fact = 'Compound lifts drive the bulk of growth and strength. Prioritize them early in the session when CNS is fresh.';
    citation = 'Schoenfeld 2010, Helms 2014';
  } else {
    // Isolation
    sets = { strength: '3-4', hypertrophy: '3-4', endurance: '2-3', general: '3' };
    reps = { strength: '6-8', hypertrophy: '10-15', endurance: '15-20', general: '10-12' };
    rest = { strength: '2 min', hypertrophy: '60-90s', endurance: '30-45s', general: '60s' };
    fact = 'Isolation work responds best to moderate-high reps with shorter rest. Focus on the mind-muscle connection.';
    citation = 'Schoenfeld 2018, Grgic 2018';
  }

  return {
    primary, secondary, sets, reps, rest,
    rir: isOly ? '2-3 reps in reserve (power-focused)' : '1-2 reps in reserve',
    frequency: isCompound ? '2×/week' : '2-3×/week',
    fact, citation,
    inferred: true  // flag so we can note this is generalized
  };
}

